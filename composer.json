{
  "name": "cobweb/svconnector_feed",
  "type": "typo3-cms-extension",
  "description": "Connector service for XML files or RSS feeds",
  "license": [
    "GPL-2.0-or-later"
  ],
  "authors": [
    {
      "name": "Francois Suter",
      "role": "Developer",
      "homepage": "https://www.ideative.ch/en/"
    }
  ],
  "autoload": {
    "psr-4": {
      "Cobweb\\SvconnectorFeed\\": "Classes/"
    }
  },
  "require": {
    "typo3/cms-core": "^13.4 || ^14.1",
    "php": "^8.2 || ^8.3 || ^8.4 || ^8.5",
    "cobweb/svconnector": "dev-develop",
    "typo3/coding-standards": "*"
  },
  "require-dev": {
    "ergebnis/composer-normalize": "^2.48",
    "friendsofphp/php-cs-fixer": "^3.88",
    "typo3/testing-framework": "^9.x-dev",
    "phpstan/phpstan": "^2.1"
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "svconnector_feed",
      "web-dir": ".Build/web"
    }
  },
  "replace": {
    "typo3-ter/svconnector_feed": "self.version"
  },
  "config": {
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true,
      "ergebnis/composer-normalize": true
    },
    "bin-dir": ".Build/bin",
    "sort-packages": true,
    "vendor-dir": ".Build/vendor"
  }
}
